#include <string>
#include <climits>

class Solution {
public:
    int myAtoi(std::string s) {
        int n = s.length();
        int i = 0;
        while (i < n && s[i] == ' ') {
            i++;
        }
        if (i == n) return 0;
        int sign = 1;
        if (s[i] == '+' || s[i] == '-') {
            sign = (s[i] == '-') ? -1 : 1;
            i++;
        }
        long result = 0;
        while (i < n && isdigit(s[i])) {
            result = result * 10 + (s[i] - '0');
            if (sign == 1 && result > INT_MAX) return INT_MAX;
            if (sign == -1 && -result < INT_MIN) return INT_MIN;
            
            i++;
        }
        
        return (int)(sign * result);
    }
};
