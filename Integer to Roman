#include <string>
#include <vector>
class Solution {
public:
    std::string intToRoman(int num) {
        struct RomanPair {
            int value;
            std::string symbol;
        };
        const RomanPair romanMap[] = {
            {1000, "M"}, {900, "CM"}, {500, "D"}, {400, "CD"},
            {100, "C"},  {90, "XC"},  {50, "L"},  {40, "XL"},
            {10, "X"},   {9, "IX"},   {5, "V"},   {4, "IV"},
            {1, "I"}
        };
        std::string result = "";
        for (const auto& pair : romanMap) {
            while (num >= pair.value) {
                result += pair.symbol;
                num -= pair.value;
            }
        }
        
        return result;
    }
};
